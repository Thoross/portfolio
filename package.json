		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"type": "module",
	"dependencies": {
		"@iconify-json/bi": "^1.2.7",
		"@iconify-json/bxl": "^1.2.4",
		"@iconify-json/bxs": "^1.2.3"
